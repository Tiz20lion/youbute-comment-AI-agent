# =============================================================================
# YouTube Comment Automation Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
#
# REQUIRED SETTINGS TO GET STARTED: (ONLY edit the VALUES with the WORD "here")
# 1. GOOGLE_API_KEY or YOUTUBE_API_KEY - Get from Google Cloud Console
# 2. OPENROUTER_API_KEY - Get from https://openrouter.ai/keys
# 3. TELEGRAM_BOT_TOKEN - Get from @BotFather on Telegram
# 4. TELEGRAM_ALLOWED_USERS - Your Telegram user ID
#
# REQUIRED FOR COMMENT POSTING:
# 5. GOOGLE_CLIENT_ID & GOOGLE_CLIENT_SECRET - OAuth2 credentials for posting
# 6. Set ENABLE_COMMENT_POSTING=true when ready to post real comments
# 
#
# Find your Telegram user ID: Send message to @userinfobot

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME="youtube-comment-bot"
ENVIRONMENT="development"
DEBUG="true"
LOG_LEVEL="INFO"

# =============================================================================
# FASTAPI CONFIGURATION
# =============================================================================
HOST="0.0.0.0"
PORT="8080"
RELOAD="true"

# =============================================================================
# GOOGLE CLOUD / YOUTUBE API CONFIGURATION
# =============================================================================
GOOGLE_API_KEY="here"
YOUTUBE_API_KEY="here"

GOOGLE_CLIENT_ID="here"
GOOGLE_CLIENT_SECRET="here"

GOOGLE_OAUTH2_SCOPES="https://www.googleapis.com/auth/youtube.force-ssl"
GOOGLE_OAUTH2_REDIRECT_URI="http://localhost:8080/oauth2callback"

YOUTUBE_MAX_RESULTS="50"
YOUTUBE_QUOTA_LIMIT="10000"

# =============================================================================
# OPENROUTER API CONFIGURATION
# =============================================================================
OPENROUTER_API_KEY="here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ✅ EXCELLENT MODEL CHOICE! google/gemini-2.0-flash-001 is perfect for content generation
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_MAX_TOKENS="2000"
OPENROUTER_TEMPERATURE="0.7"

# Content Analyzer - Optimized for analysis
CONTENT_ANALYZER_MODEL="google/gemini-2.0-flash-001"
CONTENT_ANALYZER_TEMPERATURE="0.3"
CONTENT_ANALYZER_MAX_TOKENS="1500"

# Comment Generator - Optimized for human-like comments
COMMENT_GENERATOR_MODEL="google/gemini-2.0-flash-001"
COMMENT_GENERATOR_TEMPERATURE="0.8"
COMMENT_GENERATOR_MAX_TOKENS="200"

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
TELEGRAM_BOT_TOKEN="here"
TELEGRAM_ALLOWED_USERS="here"

# =============================================================================
# LANGGRAPH WORKFLOW CONFIGURATION
# =============================================================================
LANGGRAPH_MAX_RETRIES="3"
LANGGRAPH_TIMEOUT="300"

# =============================================================================
# DATA STORAGE CONFIGURATION
# =============================================================================
DATA_DIRECTORY="./data"
CHANNELS_DIRECTORY="./data/channels"
LOGS_DIRECTORY="./logs"
TEMP_DIRECTORY="./temp"

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
YOUTUBE_QUOTA_PER_DAY="10000"
YOUTUBE_REQUESTS_PER_SECOND="1"
OPENROUTER_REQUESTS_PER_MINUTE="60"
TELEGRAM_MESSAGES_PER_SECOND="1"

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
# Agent 1: Channel Parser
CHANNEL_PARSER_MAX_VIDEOS="10"
CHANNEL_PARSER_TIMEOUT="60"

# Agent 2: Description Extractor (Added missing settings)
DESCRIPTION_TIMEOUT="60"
DESCRIPTION_RETRY_ATTEMPTS="2"

# Agent 3: Content Scraper
MAX_COMMENTS_PER_VIDEO="100"
COMMENTS_ORDER="relevance"
SCRAPER_TIMEOUT="180"

# Agent 4: Content Analyzer
ANALYSIS_TIMEOUT="300"

# Agent 5: Comment Generator
COMMENT_MAX_LENGTH="400"
COMMENT_MIN_LENGTH="150"
COMMENT_STYLE="engaging"

# Agent 6: Comment Poster
COMMENT_POST_DELAY="10"
COMMENT_POST_RETRIES="3"
COMMENT_POST_TIMEOUT="60"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_FORMAT="json"
LOG_FILE="./logs/app.log"
LOG_MAX_SIZE="10MB"  # Not used with daily rotation, kept for compatibility
LOG_BACKUP_COUNT="10"  # Keep 10 days of daily log files

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGINS="*"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_COMMENT_POSTING="true"
DEV_SKIP_RATE_LIMITS="false" 